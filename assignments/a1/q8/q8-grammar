skip WS '\s+'

token TOKEN_KEY 'token'
token SKIP_KEYWORD 'skip'

token COMMENT '#.*'

token TOKEN_NAME '[A-z]+'

token IDENTIFIER ''[a-zA-Z0-9_\\\.\+\-]*''

%

<line>Comment ::= COMMENT
<line>NoComment ::= <rule>

<rule>Skip ::= SKIP_KEYWORD IDENTIFIER
<rule>Tok ::= <token_key> IDENTIFIER

<token_key>OptedToken ::= TOKEN_KEY IDENTIFIER
<token_key>NoToken ::= IDENTIFIER